// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TarotCard {
  id              Int     @id
  name            String
  arcana          String
  suit            String?
  rankKey         String?
  uprightMeaning  String  @db.Text
  reversedMeaning String  @db.Text
  element         String?
  emoji           String

  @@index([arcana])
}

model Spread {
  id          String   @id
  name        String
  description String   @db.Text
  cardCount   Int
  positions   Json
  hot         Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  readings ReadingRecord[]
}

model ReadingRecord {
  id             String   @id @default(cuid())
  clerkUserId    String
  spreadId       String
  spread         Spread   @relation(fields: [spreadId], references: [id], onDelete: Cascade)
  question       String?
  drawResult     Json
  interpretation String   @db.Text
  createdAt      DateTime @default(now())

  @@index([clerkUserId, createdAt])
}
